# --- PostgreSQL ---
# DSN pro připojení k databázi. Uživatel musí mít CREATE TABLE práva (kvůli Alembic migraci).
DATABASE_URL=postgresql+psycopg://blondi:heslo@localhost:5432/blondi

# --- Výchozí hodnoty pro Spot robota ---
# Použijí se jako prefill v Login kroku wizardu. Operátor může přepsat.
SPOT_DEFAULT_IP=192.168.80.3
SPOT_TIMEOUT_SECONDS=15

# --- Fiducial check ---
# Maximální vzdálenost (v metrech), kdy považujeme fiducial za "u Spota".
FIDUCIAL_DISTANCE_THRESHOLD_M=2.0

# --- OCR ---
# Cesta (relativní k rootu projektu) k YOLO modelu pro detekci SPZ.
OCR_YOLO_MODEL=ocr/license-plate-finetune-v1m.pt
# Název fast-plate-ocr modelu pro čtení textu SPZ.
OCR_TEXT_ENGINE=european-plates-mobile-vit-v2-model
# Minimální YOLO confidence pro přijetí detekce.
OCR_DETECTION_MIN_CONFIDENCE=0.5

# --- Credentials (Windows Credential Locker) ---
# Service prefix pro keyring. Pod tímto prefixem se ukládají hesla.
KEYRING_SERVICE=blondi.spot

# --- Operátor / auditní stopa ---
# Volitelné — pokud je vyplněné, zapíše se do spot_runs.operator_label a maps.created_by_operator.
OPERATOR_LABEL=

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
